<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.ProfileController" stylesheets="@../styles/mainScreenStyle.css" spacing="10" alignment="CENTER" styleClass="profile-container" >
    <Label text="Edit Profile" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
    
    <TextField fx:id="userIdField" editable="false" promptText="User ID (Read Only)" />
    <TextField fx:id="roleField" editable="false" promptText="Role (Read Only)" />
    <TextField fx:id="orgIdField" editable="false" promptText="Organization ID (Read Only)" />
    <TextField fx:id="fullNameField" promptText="Full Name" />
    <TextField fx:id="emailField" promptText="Email" />
    <PasswordField fx:id="passwordField" promptText="New Password" />
    
    <Button text="Save Changes" onAction="#handleUpdateProfile" style="-fx-background-color: #27ae60; -fx-text-fill: white;"/>
</VBox>
