<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:id="rootPane" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="550.0" prefWidth="750.0" stylesheets="@../styles/mainScreenStyle.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.mainScreenController">
  
    <top>
        <MenuBar BorderPane.alignment="CENTER">
            <menus>
                <Menu mnemonicParsing="false" text="File">
                    <items>
                        <MenuItem mnemonicParsing="false" onAction="#handleExit" text="Exit" />
                    </items>
                </Menu>
                <Menu mnemonicParsing="false" text="Format">
                    <items>
                        <Menu mnemonicParsing="false" text="Font Family">
                            <items>
                                <MenuItem mnemonicParsing="false" onAction="#changeFontFamily" text="Arial" />
                                <MenuItem mnemonicParsing="false" onAction="#changeFontFamily" text="Verdana" />
                                <MenuItem mnemonicParsing="false" onAction="#changeFontFamily" text="Courier New" />
                            </items>
                        </Menu>
                        <Menu mnemonicParsing="false" text="Font Size">
                            <items>
                                <MenuItem mnemonicParsing="false" onAction="#changeFontSize" text="12px" />
                                <MenuItem mnemonicParsing="false" onAction="#changeFontSize" text="16px" />
                                <MenuItem mnemonicParsing="false" onAction="#changeFontSize" text="20px" />
                            </items>
                        </Menu>
                        <Menu mnemonicParsing="false" text="Background Color">
                            <items>
                                <MenuItem mnemonicParsing="false" onAction="#lightMode" text="light" />
                                <MenuItem mnemonicParsing="false" onAction="#DarkMode" text="Dark" />
                            </items>
                        </Menu>
                    </items>
                </Menu>
                <Menu mnemonicParsing="false" text="Help">
                    <items>
                        <MenuItem mnemonicParsing="false" onAction="#handleAbout" text="About App" />
                    </items>
                </Menu>
            </menus>
        </MenuBar>
    </top>
   
   <center>
      <VBox alignment="CENTER" fillWidth="false" prefHeight="200.0" prefWidth="100.0" spacing="20.0" styleClass="main-container" BorderPane.alignment="CENTER">
         <children>
            <VBox alignment="CENTER" prefHeight="380.0" prefWidth="360.0" styleClass="login-card">
               <children>
                  <Label styleClass="login-title" text="Unified Aid Management System">
                     <VBox.margin>
                        <Insets bottom="5.0" />
                     </VBox.margin>
                  </Label>
                  <Label styleClass="login-subtitle" text="Sign in to your user account">
                     <VBox.margin>
                        <Insets bottom="30.0" />
                     </VBox.margin>
                  </Label>
                 
                  <VBox prefWidth="100.0" spacing="5.0" alignment="CENTER_LEFT">
                     <children>
                        <Label styleClass="input-label" text="Username" />
                        <TextField promptText="Enter your username or email" styleClass="text-field" fx:id="usernameField"/>
                     </children>
                     <VBox.margin>
                        <Insets bottom="15.0" />
                     </VBox.margin>
                  </VBox>
              
                  <VBox prefWidth="100.0" spacing="5.0" alignment="CENTER_LEFT">
                     <children>
                        <Label styleClass="input-label" text="Password" />
                        <PasswordField promptText="Enter your password" styleClass="password-field" fx:id="passwordField" />
                     </children>
                     <VBox.margin>
                        <Insets bottom="25.0" />
                     </VBox.margin>
                  </VBox>
                 
                  <Button mnemonicParsing="false" prefHeight="40.0" prefWidth="300.0" styleClass="login-button" text="Login" onAction="#handleLogin"/>
               </children>
               <padding>
                  <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
               </padding>
            </VBox>
         </children>
      </VBox>
   </center>
</BorderPane>