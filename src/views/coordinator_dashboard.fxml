<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:id="adminRoot" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="650.0" prefWidth="950.0" stylesheets="@../styles/adminStyle.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.CoordinatorController">
   
    <left>
        <VBox prefWidth="230.0" styleClass="sidebar" spacing="10.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets left="10.0" right="10.0" />
            </padding>
            <children>
                <VBox alignment="CENTER" prefHeight="80.0" styleClass="sidebar-header">
                    <children>
                        <Label styleClass="sidebar-title" text="UAMS - GAZA" />
                        <Label styleClass="sidebar-subtitle" text="Coordinator Portal" />
                    </children>
                </VBox>
                
                <Button mnemonicParsing="false" onAction="#showDashboard" prefHeight="45.0" prefWidth="210.0" styleClass="sidebar-btn" text="📊 Dashboard" />
                <Button mnemonicParsing="false" onAction="#showProfile" prefHeight="45.0" prefWidth="210.0" styleClass="sidebar-btn" text="👤 My Profile" />
                <Button mnemonicParsing="false" onAction="#showFamilyManagement" prefHeight="45.0" prefWidth="210.0" styleClass="sidebar-btn" text="👨‍👩‍👧‍👦 Family Management" />
                <Button mnemonicParsing="false" onAction="#showAidDistribution" prefHeight="45.0" prefWidth="210.0" styleClass="sidebar-btn" text="🎁 Aid Distribution" />
                <Button mnemonicParsing="false" onAction="#showChangePassword" prefHeight="45.0" prefWidth="210.0" styleClass="sidebar-btn" text="🔑 Change Password" />
                
                <VBox alignment="BOTTOM_CENTER" VBox.vgrow="ALWAYS" prefHeight="100.0">
                    <padding>
                        <Insets bottom="20.0" />
                    </padding>
                    <children>
                        <Button mnemonicParsing="false" onAction="#handleLogout" prefHeight="40.0" prefWidth="210.0" styleClass="logout-btn" text="🚪 Logout" />
                    </children>
                </VBox>
            </children>
        </VBox>
    </left>
    
    <center>
        <VBox fx:id="contentArea" prefHeight="200.0" prefWidth="100.0" styleClass="content-pane" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
            </padding>
            <children>
                <Label styleClass="content-title" text="Coordinator Dashboard" />
                <Label styleClass="content-subtitle" text="Manage your organizational aid and family data" />
                </children>
        </VBox>
    </center>
</BorderPane>
